# Copy to scripts/autorg_local.env and edit all values.

# ===== Paths =====
REPO_ROOT=/workspace/AutoRG-Brain
MODEL_FOLDER=/home/users/tomomasa_yamasaki/download_rgv2_data/AutoRG_Project/checkpoints/RG_v2/RG_v2
CHK_NAME=AutoRG_Brain_RGv2
SEG_PRETRAINED=/home/users/tomomasa_yamasaki/download_rgv2_data/AutoRG_Project/checkpoints/RG_v2/RG_v2/AutoRG_Brain_RGv2.model
RADGENOME_ROOT=/home/users/tomomasa_yamasaki/download_rgv2_data/AutoRG_Project/datasets/RadGenome_Metadata
OUTPUT_ROOT=/home/users/tomomasa_yamasaki/AutoRG_Experiments/Results

# ===== Runtime =====
CONDA_ENV_NAME=autorg-brain
PYTHON_VERSION=3.10
CUDA_VISIBLE_DEVICES=0
NUM_THREADS_PREPROCESS=6
NUM_THREADS_NIFTI_SAVE=2

# ===== Data files =====
# split file should contain test IDs or case dict used by your local metadata.
SPLIT_JSON=${RADGENOME_ROOT}/train_val_test_split.json
# Optional: case metadata JSON for report lookup (can be same as split json if it includes report).
CASE_METADATA_JSON=${RADGENOME_ROOT}/case_dic.json

# ===== Generated files =====
TEST_FILE_JSON=${OUTPUT_ROOT}/test_file_rg_v2.json
PRED_JSON=${OUTPUT_ROOT}/pred_report.json
METRIC_JSON=${OUTPUT_ROOT}/table2_metrics.json

# ===== Eval behavior =====
# One of: pred_global_report,pred_region_concat,pred_report
PRED_FIELD=pred_global_report
# If report is absent in split/case metadata, set STRICT_REPORT=0 to skip metric calculation.
STRICT_REPORT=1
